<!-- QUOTE FORM -->
<section id="quote" class="section-padding bg-white">
  <div class="container">
    <h2 class="fw-bold text-center mb-4">Angebot anfragen</h2>
    <div class="row justify-content-center">
      <div class="col-lg-8">
        <form action="send_request.php" method="POST" enctype="multipart/form-data">
          <div class="row g-3">
            <div class="col-md-6">
              <input type="text" class="form-control" name="name" placeholder="Name" required>
            </div>
            <div class="col-md-6">
              <input type="text" class="form-control" name="company" placeholder="Firma (optional)">
            </div>
            <div class="col-md-6">
              <input type="email" class="form-control" name="email" placeholder="E-Mail" required>
            </div>
            <div class="col-md-6">
              <input type="text" class="form-control" name="phone" placeholder="Telefon (optional)">
            </div>
            <div class="col-12">
              <select name="project_type" class="form-select" required>
                <option value="" selected disabled>Projektart</option>
                <option>T-Shirt Druck</option>
                <option>Lasergravur</option>
                <option>Aufkleber / Vinyl</option>
                <option>3D-Druck</option>
                <option>Personalisierte Geschenke</option>
                <option>Firmenauftrag (B2B)</option>
                <option>Werbeartikel</option>
                <option>Sonstiges</option>
              </select>
            </div>
            <div class="col-md-6">
              <input type="text" class="form-control" name="quantity" placeholder="Menge">
            </div>
            <div class="col-md-6">
              <input type="text" class="form-control" name="sizes" placeholder="Größen">
            </div>
            <div class="col-12">
              <textarea class="form-control" rows="4" name="details" placeholder="Projektdetails" required></textarea>
            </div>
            <div class="col-12 text-center">
              <button class="btn btn-accent px-5">Anfrage senden</button>
            </div>
          </div>
        </form>

      </div>
    </div>
  </div>
</section>

