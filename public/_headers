# Cloudflare _headers — cache policy for static assets.

# Hashed build assets: immutable, long cache.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Generated image variants.
/gallery-thumbs/*
  Cache-Control: public, max-age=31536000, immutable
/gallery-full/*
  Cache-Control: public, max-age=2592000
/og/*
  Cache-Control: public, max-age=604800

# Icons / static media.
/*.svg
  Cache-Control: public, max-age=604800
/*.png
  Cache-Control: public, max-age=604800
/*.ico
  Cache-Control: public, max-age=604800
# Product/content images (filenames aren't fingerprinted, so not immutable).
/*.webp
  Cache-Control: public, max-age=2592000
/*.jpg
  Cache-Control: public, max-age=604800

# SEO files.
/sitemap.xml
  Cache-Control: public, max-age=3600
/robots.txt
  Cache-Control: public, max-age=3600
/manifest.json
  Cache-Control: public, max-age=86400

# Baseline security headers for static-asset responses. (SSR HTML never passes
# through _headers on Workers — src/server.ts sets the same headers for pages.)
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
