{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "inkyhaus-app",
  "compatibility_date": "2025-09-24",
  "compatibility_flags": ["nodejs_compat"],
  "main": "src/server.ts"
  // Custom domain (inkyhaus.de) is attached via the Cloudflare dashboard
  // (Workers & Pages → inkyhaus-app → Domains & Routes) once the zone is live —
  // kept out of config so deploys never depend on DNS state.
}
